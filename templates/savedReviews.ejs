<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>My Reviews - Restaurant Finder</title>
    <link rel="stylesheet" href="/css/style.css">
</head>
<body>
    <nav>
        <div class="nav-container">
            <a href="/" class="logo"><span>🍽️</span> RestaurantFinder</a>
            <div class="nav-links">
                <a href="/">Search</a>
                <a href="/reviews">My Reviews</a>
            </div>
        </div>
    </nav>

    <div class="container">
        <div class="page-header">
            <h1>My Reviews</h1>
            <p>All your saved restaurant reviews</p>
        </div>

        <% if (error) { %>
            <div class="error-message"><%= error %></div>
        <% } %>

        <% if (reviews.length > 0) { %>
            <div class="actions-bar">
                <span class="badge" style="background-color: rgba(245, 158, 11, 0.15); color: #f59e0b; padding: 0.3rem 0.75rem; border-radius: 20px; font-size: 0.8rem; font-weight: 600;">
                    <%= reviews.length %> review<%= reviews.length !== 1 ? 's' : '' %>
                </span>
                <form action="/reviews/deleteAll" method="POST" style="display: inline;"
                      onsubmit="return confirm('Are you sure you want to delete ALL reviews?');">
                    <button type="submit" class="btn btn-danger btn-small" id="deleteAllBtn">🗑️ Remove All</button>
                </form>
            </div>

            <div class="reviews-list">
                <% reviews.forEach(function(review) { %>
                    <div class="review-card">
                        <div class="review-header">
                            <div>
                                <h3><%= review.restaurantName %></h3>
                                <div class="stars-display">
                                    <% for (let i = 1; i <= 5; i++) { %>
                                        <% if (i <= review.rating) { %>★<% } else { %><span class="empty">★</span><% } %>
                                    <% } %>
                                </div>
                            </div>
                            <form action="/reviews/delete/<%= review._id %>" method="POST" style="display: inline;">
                                <button type="submit" class="btn btn-danger btn-small" title="Delete review">✕</button>
                            </form>
                        </div>

                        <div class="review-meta">
                            <% if (review.restaurantAddress && review.restaurantAddress !== "N/A") { %>
                                <span class="meta-tag">📍 <%= review.restaurantAddress %></span>
                            <% } %>
                            <% if (review.city) { %>
                                <span class="meta-tag">🏙️ <%= review.city %></span>
                            <% } %>
                            <% if (review.cuisine && review.cuisine !== "any") { %>
                                <span class="meta-tag">🍴 <%= review.cuisine %></span>
                            <% } %>
                        </div>

                        <% if (review.notes) { %>
                            <div class="review-notes"><%= review.notes %></div>
                        <% } %>

                        <div class="review-footer">
                            <span class="review-date"><%= new Date(review.createdAt).toLocaleDateString('en-US', { year: 'numeric', month: 'long', day: 'numeric' }) %></span>
                        </div>
                    </div>
                <% }); %>
            </div>
        <% } else { %>
            <div class="empty-state">
                <div class="icon">📝</div>
                <h3>No reviews yet</h3>
                <p>Search for restaurants and start saving your reviews!</p>
                <a href="/" class="btn btn-primary">🔍 Find Restaurants</a>
            </div>
        <% } %>
    </div>
</body>
</html>
